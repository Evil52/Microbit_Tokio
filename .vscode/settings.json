{
    // НЕ добавлять --all-features в Run/Debug codelens (host-only фичи ломают thumbv7em).
    "rust-analyzer.cargo.features": [],
    "rust-analyzer.runnables.extraArgs": [],
    "rust-analyzer.runnables.extraTestBinaryArgs": [],
